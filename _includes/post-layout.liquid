---
layout: layout.liquid
---

<main>

    <h1>{{ pageTitle }}</h1>

    <p>
        Posted on: <time datetime="{{ page.date | postDate }}">{{ page.date | readablePostDate }}</time>

        {% if dateUpdate %}
            , last updated on: <time datetime="{{ dateUpdate | postDate }}">{{ dateUpdate | readablePostDate }}</time>
        {% endif  %}
    </p>

    {{ content }}

</main>

{% include 'webmentions' %}
